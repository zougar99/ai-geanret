{
  "name": "ai-geanret",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:app": "cross-env ELECTRON_DEV=1 concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "start:desktop": "npm run build && electron .",
    "pack:win": "vite build && electron-builder --win",
    "pack:portable": "vite build && electron-builder --win portable"
  },
  "dependencies": {
    "browserslist": "^4.28.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.0",
    "electron-builder": "^26.0.0",
    "typescript": "~5.8.0",
    "vite": "^6.3.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.aige.anret",
    "productName": "AI Geanret",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
